{
  "name": "infomii-mobile",
  "version": "1.0.2",
  "main": "index.ts",
  "dependencies": {
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-iap": "^12.16.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.11",
    "eas-cli": "^20.1.0",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "EXPO_NO_METRO_LAZY=1 expo start --host lan",
    "start:clear": "EXPO_NO_METRO_LAZY=1 expo start -c --host lan",
    "start:localhost": "EXPO_NO_METRO_LAZY=1 expo start -c --host localhost",
    "start:tunnel": "EXPO_NO_METRO_LAZY=1 expo start -c --tunnel",
    "start:8082": "EXPO_NO_METRO_LAZY=1 expo start -c --host lan --port 8082",
    "kill-metro": "lsof -ti :8081 | xargs kill -9 2>/dev/null || true",
    "clean": "rm -rf .expo node_modules/.cache",
    "restart": "npm run kill-metro && npm run clean && EXPO_NO_METRO_LAZY=1 expo start -c --host lan",
    "restart:sim": "npm run kill-metro && npm run clean && EXPO_NO_METRO_LAZY=1 expo start -c --host localhost",
    "restart:tunnel": "npm run kill-metro && npm run clean && EXPO_NO_METRO_LAZY=1 expo start -c --tunnel",
    "open:lan": "open exp://$(ipconfig getifaddr en0 2>/dev/null || echo 127.0.0.1):8081",
    "android": "EXPO_NO_METRO_LAZY=1 expo start --android --host lan",
    "ios": "EXPO_NO_METRO_LAZY=1 expo start --ios --host localhost",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "icons:generate": "python3 scripts/generate-icon-assets.py"
  },
  "private": true
}
