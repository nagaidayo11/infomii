{
  "expo": {
    "name": "Infomii",
    "slug": "infomii",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "infomii",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.infomii.app"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
