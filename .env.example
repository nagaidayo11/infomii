# OpenAI（AIページ生成で使用）
# https://platform.openai.com/api-keys で発行
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe（決済）
STRIPE_SECRET_KEY=sk_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_PRICE_ID=price_xxxx           # Pro月額 ¥1,280（税込）
STRIPE_BUSINESS_PRICE_ID=price_xxxx      # Business月額 ¥3,480（税込）
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxxx    # Pro年額 ¥12,800（月額10ヶ月分・2ヶ月お得）
STRIPE_BUSINESS_ANNUAL_PRICE_ID=price_xxxx # Business年額 ¥34,800（月額10ヶ月分・2ヶ月お得）

# 本番URL（任意）
# NEXT_PUBLIC_APP_URL=https://www.infomii.com

# App Store / Universal Links（10文字の Apple Team ID）
# APPLE_TEAM_ID=XXXXXXXXXX

# 審査用デモアカウント作成（npm run app-store:seed-review）
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# APP_STORE_REVIEW_PASSWORD=strong-password-for-review@infomii.com

# Google Analytics 4（本番ビルドかつ設定時のみ送信。App Router の全ルートで page_view）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-TJCXK31H9W
